<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a4a1a"/>
      <stop offset="100%" style="stop-color:#0d2b0a"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#a8d672"/>
      <stop offset="100%" style="stop-color:#5a9a3a"/>
    </linearGradient>
  </defs>
  
  <circle cx="256" cy="256" r="240" fill="url(#bg)" stroke="url(#glow)" stroke-width="16"/>
  
  <circle cx="256" cy="256" r="180" fill="none" stroke="url(#glow)" stroke-width="4" opacity="0.5"/>
  
  <text x="256" y="280" font-size="180" text-anchor="middle" fill="#a8d672">🌿</text>
  
  <circle cx="256" cy="256" r="200" fill="none" stroke="#a8d672" stroke-width="2" opacity="0.3">
    <animate attributeName="r" values="200;210;200" dur="3s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0.3;0.1;0.3" dur="3s" repeatCount="indefinite"/>
  </circle>
</svg>